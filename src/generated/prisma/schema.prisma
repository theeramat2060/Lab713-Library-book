// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model book {
  id       Int    @id @default(autoincrement())
  title    String
  isbn     String
  category String
  authorId Int
}
